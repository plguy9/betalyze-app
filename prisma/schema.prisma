generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- Cache minimal pour Betalyze ---
model Team {
  id           Int       @id @default(autoincrement())
  sport        String
  externalId   String?
  name         String
  abbreviation String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  players      Player[]

  @@unique([sport, externalId])
}

model Player {
  id         Int       @id @default(autoincrement())
  sport      String
  externalId String?
  firstName  String
  lastName   String
  position   String?
  teamId     Int?
  team       Team?     @relation(fields: [teamId], references: [id])

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([sport, lastName, firstName])
  @@unique([sport, externalId])
}

model NflDefenseDvp {
  id            Int      @id @default(autoincrement())
  season        String
  window        String
  context       String
  teamId        Int
  teamName      String?
  teamAbbr      String?
  position      String
  games         Int
  ffpTotal      Float
  ffpPerGame    Float
  metrics       Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([season, window, context, teamId, position])
  @@index([season, window, context, position])
}
